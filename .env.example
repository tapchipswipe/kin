# Supabase (required)
# From your Supabase project settings or Vercel Marketplace integration
VITE_SUPABASE_URL="https://your-project.supabase.co"
VITE_SUPABASE_ANON_KEY="your-anon-key"

# Gemini AI (server-side only — do NOT prefix with VITE_)
GEMINI_API_KEY="your-gemini-api-key"

# Google Maps (build-time injection via vite.config.ts)
GOOGLE_MAPS_PLATFORM_KEY="your-google-maps-key"

# Optional: custom Google Maps map ID
VITE_GOOGLE_MAPS_MAP_ID=""

# App URL (used for OAuth/password reset redirects in production)
APP_URL="https://your-app.vercel.app"
